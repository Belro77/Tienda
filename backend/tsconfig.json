{
  "compilerOptions": {
    "target": "ES2020",
 "module": "Node16",

    "rootDir": "src",
    "outDir": "dist",

    "esModuleInterop": true,
  "moduleResolution": "Node16",
  
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}